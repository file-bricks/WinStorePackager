# =============================================================================
# .gitignore Template fuer Software Entwicklung Projekte
# Kopieren und als .gitignore im Projektroot ablegen
# Projektspezifische Eintraege am Ende anfuegen
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/

# ---- Virtuelle Umgebungen ----
venv/
.venv/
env/
.env/

# ---- Interne Steuerungsdateien (NIEMALS in Git!) ----
AUFGABEN.txt
TEST.txt
TESTS.txt
TESTERGEBNISSE.txt
BUGREPORT.md
DIAGNOSE_REPORT.md
tmpclaude-*

# ---- Persoenliche / Sensible Daten ----
_USER/
.env
.env.*
credentials.json
client_secret*.json
token.json
secrets.*
*.pem
*.key
keyring/

# ---- Build-Artefakte & Releases ----
releases/
_WARTUNG/
*.exe
*.msi
*.msix
*.appx
*.spec
*.tmp
*.zip
.licenses_cache.json

# ---- IDE & Editoren ----
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Betriebssystem ----
desktop.ini
Thumbs.db
.DS_Store
ehthumbs.db

# ---- Standard-Patterns ----
PLAN.txt
_archive/
_private/
*.log
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Projektspezifisch ----
settings_store_packager.json
store_package/
*.pfx
